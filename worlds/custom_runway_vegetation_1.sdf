    <include><uri>model://pine_tree</uri><name>j_pine_8</name><pose>-45 55 0 0 0 60</pose></include>
    <include><uri>model://pine_tree</uri><name>j_pine_9</name><pose>50 -55 0 0 0 85</pose></include>
    <include><uri>model://pine_tree</uri><name>j_pine_10</name><pose>-65 -15 0 0 0 35</pose></include>
    <include><uri>model://pine_tree</uri><name>j_pine_11</name><pose>70 30 0 0 0 15</pose></include>
    <include><uri>model://pine_tree</uri><name>j_pine_12</name><pose>-25 65 0 0 0 90</pose></include>
