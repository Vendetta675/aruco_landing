    <include><uri>model://pine_tree</uri><name>j_pine_18</name><pose>-15 -60 0 0 0 15</pose></include>

    <include><uri>model://oak_tree</uri><name>j_oak_1</name><pose>45 25 0 0 0 30</pose></include>
    <include><uri>model://oak_tree</uri><name>j_oak_2</name><pose>-30 50 0 0 0 80</pose></include>
    <include><uri>model://oak_tree</uri><name>j_oak_3</name><pose>55 -35 0 0 0 15</pose></include>
    <include><uri>model://oak_tree</uri><name>j_oak_4</name><pose>-48 -20 0 0 0 110</pose></include>
