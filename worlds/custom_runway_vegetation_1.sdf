    <include><uri>model://oak_tree</uri><name>j_oak_14</name><pose>-55 60 0 0 0 115</pose></include>
    <include><uri>model://oak_tree</uri><name>j_oak_15</name><pose>30 70 0 0 0 50</pose></include>

